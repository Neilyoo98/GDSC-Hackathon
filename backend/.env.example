# Required
OPENAI_API_KEY=sk-proj-...             # GPT-5.5 — use US base URL below
OPENAI_BASE_URL=https://us.api.openai.com/v1

GITHUB_TOKEN=ghp_...                   # GitHub PAT with repo write access
TARGET_REPO=your-username/aubi-target  # repo whose issues AUBI should poll/fix
AUBI_TENANT_ID=hackathon
AUBI_TEAM_ID=default

# Services
AGENTS_SERVICE_URL=https://your-backend.railway.app

# Qdrant Cloud
QDRANT_URL=https://<cluster-id>.us-east-1-1.aws.cloud.qdrant.io
QDRANT_API_KEY=<your-qdrant-api-key>
