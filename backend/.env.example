# LLM Providers
OPENAI_API_KEY=
OPENAI_BASE_URL=https://us.api.openai.com/v1
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Default Models
DEFAULT_ORCHESTRATOR_MODEL=moonshotai/kimi-k2.5:nitro
DEFAULT_RESEARCH_MODEL=moonshotai/kimi-k2.5:nitro
DEEP_AGENT_MODEL=moonshotai/kimi-k2.5:nitro
THREAD_TITLE_MODEL=gpt-5.4

# Deep Agent SDK / Reliability
# Set DEEP_AGENT_SDK_MODE=legacy for immediate rollback to pre-SDK-first behavior.
DEEP_AGENT_SDK_MODE=sdk_first
DEEP_AGENT_RELIABILITY_MODE=middleware
DEEP_AGENT_OPENAI_RESPONSES_REQUIRED=true
DEEP_AGENT_FILTER_CONVERSATION_HISTORY_FILES=true
# Optional JSON override map:
# DEEP_AGENT_SUBAGENT_MODEL_MAP_JSON={"research-agent":"moonshotai/kimi-k2.5:nitro","web-researcher":"moonshotai/kimi-k2.5:nitro","mentor-matcher":"moonshotai/kimi-k2.5:nitro","storyteller":"moonshotai/kimi-k2.5:nitro","integration-agent":"moonshotai/kimi-k2.5:nitro","folder-file-agent":"moonshotai/kimi-k2.5:nitro","slide-builder":"moonshotai/kimi-k2.5:nitro","image-generator":"openai:gpt-4o","data-analyst":"openai:gpt-4o","general-purpose":"moonshotai/kimi-k2.5:nitro"}

# Deep Agent Circuit Breaker
DEEP_AGENT_TOOL_FAILURE_LIMIT=3
DEEP_AGENT_TOOL_FAILURE_TTL_SECONDS=900
DEEP_AGENT_MODEL_FIRST_TOKEN_TIMEOUT_SECONDS=180
DEEP_AGENT_MODEL_IDLE_TIMEOUT_SECONDS=480
DEEP_AGENT_SQL_PREVIEW_TABLE_RESOLVER_V1=false
PASTE_FILE_TOKEN_LIMIT=100000

# Durable Run Streaming (Postgres-backed)
RUN_EXECUTOR_ENABLED=true
RUN_EXECUTOR_CONCURRENCY=8
RUN_EXECUTOR_POLL_INTERVAL_MS=250
RUN_EXECUTOR_HEARTBEAT_SECONDS=10
RUN_EXECUTOR_CLAIM_TTL_SECONDS=45
RUN_EVENTS_POLL_INTERVAL_MS=250
RUN_EVENTS_FETCH_LIMIT=200
RUN_EVENTS_HEARTBEAT_SECONDS=15
RUN_TEXT_COALESCE_MS=200
RUN_TEXT_COALESCE_MAX_CHUNKS=20
RUN_STREAM_TOKEN_TTL_SECONDS=900
RUN_STREAM_TOKEN_SECRET=

# External Services
COGNEE_API_URL=http://localhost:8001
GRAPHITI_API_URL=http://localhost:8002
COGNEE_SECRET_KEY=

# Firecrawl (self-hosted or cloud)
FIRECRAWL_PROVIDER=self_hosted
FIRECRAWL_API_URL=https://api.firecrawl.dev
FIRECRAWL_API_KEY=
FIRECRAWL_HOSTED_API_URL=https://api.firecrawl.dev
FIRECRAWL_HOSTED_API_KEY=

# Redis (for checkpointing)
# Local: redis://localhost:6379
# Railway: Use ${{Redis.REDIS_URL}} variable reference
REDIS_URL=redis://localhost:6379
# Checkpointer backend selection
# - auto: prefer Postgres when POSTGRES_URL is set, else Redis
# - postgres: force Postgres (fails if POSTGRES_URL not available)
# - redis: force Redis
CHECKPOINTER_BACKEND=auto
# Optional read fallback for legacy checkpoints (redis or none)
CHECKPOINTER_READ_FALLBACK=redis
# Migrate Redis checkpoints to Postgres on read
CHECKPOINTER_MIGRATE_ON_READ=true
# Log which backend served checkpoint reads
CHECKPOINTER_LOG_BACKEND=true

# PostgreSQL (for LangGraph store - files, memories, artifacts)
# Local: postgresql://user:pass@localhost:5432/dbname
# Railway: Use ${{Postgres.DATABASE_URL}} variable reference
POSTGRES_URL=

# Tenant SQL tools (live data access)
# Single DB for all tenants:
# TENANT_SQL_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/db
# Per-tenant mapping (JSON):
# TENANT_SQL_DATABASE_URLS={"default":{"url":"postgresql+psycopg://user:pass@host/db","schema":"public","include_tables":"users,teams"},"tenant_a":"mssql+pyodbc://user:pass@server/db?driver=ODBC+Driver+18+for+SQL+Server"}
TENANT_SQL_DATABASE_URL=
TENANT_SQL_DATABASE_URLS=
TENANT_SQL_SCHEMA=
TENANT_SQL_SCHEMA_PREFIX=
TENANT_SQL_INCLUDE_TABLES=
TENANT_SQL_SAMPLE_ROWS_IN_TABLE_INFO=2
TENANT_SQL_STATEMENT_TIMEOUT_MS=30000
TENANT_SQL_CONTEXT_TTL_SECONDS=21600
TENANT_SQL_CONTEXT_SUMMARY_TABLE_CAP=10
TENANT_SQL_CONTEXT_SUMMARY_COLUMN_CAP=8

# Integration Encryption Key (generate with: openssl rand -hex 32)
# Required for encrypting integration credentials at rest
# For local-only temporary testing, you may set ALLOW_EPHEMERAL_INTEGRATION_ENCRYPTION=true
# (credentials become unreadable after restart).
INTEGRATION_ENCRYPTION_KEY=
ALLOW_EPHEMERAL_INTEGRATION_ENCRYPTION=false

# File Storage (S3-compatible)
FILE_STORAGE_PROVIDER=inline
FILE_STORAGE_BUCKET=
FILE_STORAGE_REGION=
FILE_STORAGE_ENDPOINT=
FILE_STORAGE_ACCESS_KEY=
FILE_STORAGE_SECRET_KEY=
FILE_STORAGE_PUBLIC_URL=
FILE_STORAGE_PRESIGN_EXPIRY_SECONDS=3600

# Server
# Railway will set PORT automatically
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO
RECURSION_LIMIT=1000

# API Security
# Generate with: openssl rand -hex 32
# By default, API key auth is required for protected routes.
# Set ALLOW_UNAUTHENTICATED_API=true only for local development.
API_KEY=
ALLOW_UNAUTHENTICATED_API=false
ENABLE_DEBUG_ENDPOINTS=false
# Fail closed on persistence backend outages by default.
# Set true only for local troubleshooting when you explicitly accept ephemeral in-memory data.
ALLOW_IN_MEMORY_PERSISTENCE_FALLBACK=false

# CORS (comma-separated origins)
# Include your frontend URL (e.g., mentor-hub-2 on Vercel or Railway)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# RAILWAY DEPLOYMENT NOTES
# =============================================================================
# Required variables to set in Railway dashboard:
# - OPENAI_API_KEY
# - POSTGRES_URL=${{Postgres.DATABASE_URL}} (add PostgreSQL plugin first)
# - REDIS_URL=${{Redis.REDIS_URL}} (add Redis plugin first)
# - COGNEE_API_URL (your cognee-service Railway URL)
# - COGNEE_SECRET_KEY
# - CORS_ORIGINS (your frontend URLs, e.g., https://your-app.vercel.app)
# - API_KEY (generate with: openssl rand -hex 32, share with frontends)
# - RUN_STREAM_TOKEN_SECRET (generate separately from API_KEY for direct SSE tokens)
#
# Optional:
# - ANTHROPIC_API_KEY (or use OPENROUTER_API_KEY for Claude models)
# - OPENAI_BASE_URL (default: https://us.api.openai.com/v1)
# - OPENROUTER_API_KEY (routes Anthropic models through OpenRouter)
# - DEFAULT_ORCHESTRATOR_MODEL (default: claude-4.6-sonnet)
# - DEFAULT_RESEARCH_MODEL (default: claude-4.6-sonnet)
# - DEEP_AGENT_MODEL (default: uses DEFAULT_ORCHESTRATOR_MODEL)
# - LOG_LEVEL (default: INFO)
# - CHECKPOINTER_BACKEND (default: auto)
# - CHECKPOINTER_READ_FALLBACK (default: redis)
# - CHECKPOINTER_MIGRATE_ON_READ (default: true)
